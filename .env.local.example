# We Live for Sundays (WLFS) — environment variables
# Copy this file to `.env.local` and fill in the values.

# Supabase — Project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase — anon/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — service role key (SERVER ONLY — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Sleeper — your league ID (from the Sleeper league URL)
SLEEPER_LEAGUE_ID=
